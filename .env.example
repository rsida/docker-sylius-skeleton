# ============================================================
# docker-sylius-skeleton — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
# .env is gitignored and will never be committed.
# ============================================================

# Project identity — used for container names, network, and Traefik router names.
# Must be unique across your local projects.
APP_NAME=sylius

# Local domain — must be added to /etc/hosts → 127.0.0.1
# Mailpit will be available at mail.<APP_DOMAIN>
APP_DOMAIN=sylius.local

# Symfony environment
APP_ENV=dev
APP_SECRET=change-me-in-production

# Traefik shared network (must match docker-base configuration)
TRAEFIK_NETWORK=traefik-net

# Database credentials
DB_ROOT_PASSWORD=root
DB_NAME=sylius
DB_USER=sylius
DB_PASSWORD=sylius
